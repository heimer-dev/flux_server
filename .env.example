PORT=3000
DATABASE_URL=postgresql://flux:flux@postgres:5432/flux
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-in-production
UPLOAD_DIR=/uploads
BASE_URL=http://localhost:3000
NODE_ENV=production
LOG_LEVEL=info

# Rate limits (optional — defaults are generous for self-hosted use)
# RL_REGISTER=100     # registrations per hour per IP (default: 100)
# RL_LOGIN=30         # logins per minute per IP (default: 30)
# RL_MESSAGE=60       # messages per minute per user (default: 60)
# RL_AVATAR=10        # avatar uploads per hour per user (default: 10)
# RL_MEDIA=30         # media uploads per hour per user (default: 30)
